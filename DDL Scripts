CREATE SEQUENCE error_log_seq
  START WITH 1
  INCREMENT BY 1
  NOCACHE
  NOCYCLE;

CREATE TABLE error_log (
  -- Primary Key
  log_id            NUMBER            NOT NULL,

  -- When it happened
  log_timestamp     TIMESTAMP         NOT NULL,

  -- Session info (from V$SESSION)
  username          VARCHAR2(100),
  os_user           VARCHAR2(100),
  machine           VARCHAR2(100),
  program           VARCHAR2(100),
  session_id        NUMBER,

  -- Where error was caught (from UTL_CALL_STACK + $$PLSQL_LINE)
  program_unit      VARCHAR2(500),
  line_number       NUMBER,

  -- Exception details
  exception_name    VARCHAR2(200),
  error_code        NUMBER,
  error_message     VARCHAR2(4000),

  -- Failed SQL: extracted from USER_SOURCE using backtrace line number
  -- Shows 2 lines before + failing line + 2 lines after for full context
  failed_sql        CLOB,

  -- Full call stack at the point log_error was called
  call_stack        CLOB,

  -- Backtrace: traces back to the line that originally raised the error
  error_backtrace   CLOB,

  CONSTRAINT error_log_pk PRIMARY KEY (log_id)
);

-- Table and column comments
COMMENT ON TABLE  error_log                  IS 'Central PL/SQL error log - all exceptions logged here';
COMMENT ON COLUMN error_log.log_id           IS 'Primary key from error_log_seq';
COMMENT ON COLUMN error_log.log_timestamp    IS 'Exact timestamp the error was logged (SYSTIMESTAMP)';
COMMENT ON COLUMN error_log.username         IS 'Oracle DB username from V$SESSION';
COMMENT ON COLUMN error_log.os_user          IS 'OS-level username from V$SESSION';
COMMENT ON COLUMN error_log.machine          IS 'Client machine name from V$SESSION';
COMMENT ON COLUMN error_log.program          IS 'Client program name from V$SESSION';
COMMENT ON COLUMN error_log.session_id       IS 'Oracle Session SID from V$SESSION';
COMMENT ON COLUMN error_log.program_unit     IS 'Package.Procedure/Function name where error was caught';
COMMENT ON COLUMN error_log.line_number      IS 'Line number in handler where log_error was called ($$PLSQL_LINE)';
COMMENT ON COLUMN error_log.exception_name   IS 'Human-readable exception name mapped from SQLCODE';
COMMENT ON COLUMN error_log.error_code       IS 'Raw SQLCODE value';
COMMENT ON COLUMN error_log.error_message    IS 'SQLERRM - full Oracle error message';
COMMENT ON COLUMN error_log.failed_sql       IS 'Source lines around the failing statement (from USER_SOURCE via backtrace)';
COMMENT ON COLUMN error_log.call_stack       IS 'Full PL/SQL call stack at the point log_error was invoked';
COMMENT ON COLUMN error_log.error_backtrace  IS 'Backtrace to original line where exception was raised';
