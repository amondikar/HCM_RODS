{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "enabledPlugins": {
        "understand-anything@Lum1104-Understand-Anything": true
    },
    "extraKnownMarketplaces": {
        "Lum1104-Understand-Anything": {
            "source": {
                "source": "github",
                "repo": "Lum1104/Understand-Anything"
            }
        }
    },
    "hooks": {
        "SessionStart": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd /home/user/HCM_RODS && python understand_onboard.py --onboard 2>/dev/null || true",
                        "statusMessage": "Generating HCM_RODS onboarding guide..."
                    }
                ]
            }
        ]
    }
}
